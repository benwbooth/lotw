use flake

# uv-managed Python venv for the agent (numpy / gymnasium + the lotw_env extension).
# `uv sync` creates/updates .venv from pyproject.toml + uv.lock; re-runs only when
# those change. After editing the Rust in lotw-env/, run `uv sync --reinstall-package
# lotw-env` (or `maturin develop`) to rebuild the extension.
watch_file pyproject.toml uv.lock
uv sync --quiet
source .venv/bin/activate
